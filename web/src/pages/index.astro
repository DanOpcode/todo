---
import TodoFilter from "../components/TodoFilter";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Todo App - Astro Islands</title>
    <style>
      :root {
        color-scheme: light;
      }

      body {
        font-family: "Merriweather", Georgia, serif;
        margin: 0;
        padding: 2rem;
        background: linear-gradient(160deg, #f5f1e8, #d5e8ea);
        color: #1d2b3a;
      }

      main {
        max-width: 720px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.86);
        border: 1px solid #c4d3d4;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Todo UI with Astro Islands</h1>
      <p>
        Static markup is rendered by Astro, while the filter below is hydrated as a single React
        island.
      </p>

      <TodoFilter client:load />
    </main>
  </body>
</html>
